# ==========================================
# BeeconMini SEED AC1 核心硬件架构配置
# ==========================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_beeconmini_seed-ac1=y

# ==========================================
# 基础系统与核心组件
# ==========================================
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# IPv6 支持
CONFIG_IPV6=y

# ==========================================
# LuCI 网页后台基础设置
# ==========================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-light=y
# 默认中文语言包
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_LUCI_DEFAULT_LANG="zh_Hans"
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ==========================================
# 专属硬件驱动与网络支持 (SFP光口、网管交换机)
# ==========================================
CONFIG_PACKAGE_kmod-sfp=y
CONFIG_PACKAGE_ethtool=y

# ==========================================
# 常用 LuCI 插件可选添加 (根据需求自行删减 # 号)
# ==========================================
# 1. 常用网管与向导
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# 2. 统计与监控
# CONFIG_PACKAGE_luci-app-statistics=y
# CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y

# 3. 动态 DNS (DDNS)
# CONFIG_PACKAGE_luci-app-ddns=y
# CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y

# 4. 网络加速 (Flow Offload / Shortcut Forwarding)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y

CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-app-2fa=y
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-app-tailscale-community=y
CONFIG_PACKAGE_luci-app-tailscale-community-zh-cn=y
CONFIG_PACKAGE_luci-app-openclash=y

# ==========================================
# OpenClash 必需的底层网络依赖项（防报错必加）
# ==========================================
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y
CONFIG_PACKAGE_kmod-tun=y

# 如果你使用的是较新的 OpenWrt（如基于 Firewall4 / nftables）
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# ==========================================
# 固件打包体积优化选项
# ==========================================
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
